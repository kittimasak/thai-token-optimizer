{
  "name": "thai-token-optimizer",
  "version": "2.0.0",
  "description": "Thai Token Optimizer v2.0 — adaptive Thai token optimization for Codex, Claude Code, Gemini CLI, OpenCode, OpenClaw, and Hermes Agent.",
  "private": false,
  "type": "commonjs",
  "scripts": {
    "test": "node --test tests/test_*.js",
    "test:ci": "node scripts/run-tests-ci.js",
    "install:codex": "node bin/thai-token-optimizer.js install codex",
    "install:claude": "node bin/thai-token-optimizer.js install claude",
    "install:all": "node bin/thai-token-optimizer.js install all",
    "tto:on": "node bin/thai-token-optimizer.js on",
    "tto:off": "node bin/thai-token-optimizer.js off",
    "tto:auto": "node bin/thai-token-optimizer.js auto",
    "tto:full": "node bin/thai-token-optimizer.js full",
    "tto:safe": "node bin/thai-token-optimizer.js safe",
    "tto:benchmark": "node bin/thai-token-optimizer.js benchmark",
    "tto:doctor": "node bin/thai-token-optimizer.js doctor",
    "tto:backup": "node bin/thai-token-optimizer.js backup all",
    "tto:compress:budget": "node bin/thai-token-optimizer.js compress --budget 500",
    "benchmark": "node bin/thai-token-optimizer.js benchmark",
    "benchmark:strict": "node bin/thai-token-optimizer.js benchmark --strict",
    "benchmark:history": "node scripts/update-benchmark-history.js",
    "benchmark:trend": "node scripts/benchmark-trend-report.js 10",
    "fleet:fixtures": "node scripts/generate-session-fixtures.js 30",
    "fleet:history": "node scripts/update-fleet-history.js --out benchmarks/fleet_history.jsonl",
    "fleet:gate": "node scripts/fleet-drift-gate.js --history benchmarks/fleet_history.jsonl --consecutive 3 --maxWasteTokens 200000 --maxUsd 10 --minConfidence 0.5",
    "calibration:history": "node scripts/update-calibration-history.js",
    "calibration:gate": "node scripts/calibration-ci-gate.js --history benchmarks/calibration_history.jsonl --maxGapPct 20 --consecutive 3",
    "doctor": "node bin/thai-token-optimizer.js doctor",
    "ci": "npm run test:ci && node bin/thai-token-optimizer.js benchmark --strict --default-policy --mtp && node bin/thai-token-optimizer.js doctor --ci"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "author": "Dr.Kittimasak Naijit",
  "bin": {
    "thai-token-optimizer": "bin/thai-token-optimizer.js",
    "tto": "bin/thai-token-optimizer.js"
  },
  "keywords": [
    "codex",
    "claude-code",
    "hooks",
    "thai",
    "token",
    "prompt-compression",
    "thai-token-optimizer",
    "gemini-cli",
    "opencode",
    "openclaw",
    "hermes-agent",
    "extension",
    "ai-coding-agent"
  ],
  "optionalDependencies": {
    "@dqbd/tiktoken": "^1.0.21",
    "gpt-tokenizer": "^2.9.0"
  }
}
